<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/panelRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/panel_bg_shape"
    android:paddingLeft="6dp"
    android:paddingRight="10dp"
    android:paddingTop="6dp"
    android:paddingBottom="6dp"
    android:gravity="center_vertical"
    android:elevation="14dp">

    <TextView
        android:id="@+id/btnDrag"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:gravity="center"
        android:text="⠿"
        android:textColor="#5EE38A"
        android:textSize="15sp" />

    <View
        android:layout_width="1dp"
        android:layout_height="18dp"
        android:background="#26FFFFFF"
        android:layout_marginStart="2dp"
        android:layout_marginEnd="4dp" />

    <TextView
        android:id="@+id/btnAddDot"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:gravity="center"
        android:text="➕"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:background="@drawable/panel_icon_ripple" />

    <TextView
        android:id="@+id/btnCapture"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:gravity="center"
        android:text="✨"
        android:textColor="#4ADE80"
        android:textSize="15sp"
        android:background="@drawable/panel_icon_ripple" />

    <TextView
        android:id="@+id/btnFeedback"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:gravity="center"
        android:text="📊"
        android:textColor="#60A5FA"
        android:textSize="14sp"
        android:background="@drawable/panel_icon_ripple" />

    <TextView
        android:id="@+id/btnPatternMatch"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:gravity="center"
        android:text="🔍"
        android:textColor="#FBBF24"
        android:textSize="14sp"
        android:background="@drawable/panel_icon_ripple" />

    <View
        android:layout_width="1dp"
        android:layout_height="18dp"
        android:background="#26FFFFFF"
        android:layout_marginStart="2dp"
        android:layout_marginEnd="2dp" />

    <TextView
        android:id="@+id/btnMinimize"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:gravity="center"
        android:text="—"
        android:textColor="#94A3B8"
        android:textSize="14sp"
        android:textStyle="bold"
        android:background="@drawable/panel_icon_ripple" />

    <TextView
        android:id="@+id/btnClose"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:gravity="center"
        android:text="✕"
        android:textColor="#F87171"
        android:textSize="13sp"
        android:textStyle="bold"
        android:background="@drawable/panel_icon_ripple" />

</LinearLayout>
