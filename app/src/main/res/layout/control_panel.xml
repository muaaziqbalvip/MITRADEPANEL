<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/panelRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/panel_bg_shape"
    android:paddingLeft="8dp"
    android:paddingRight="12dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:gravity="center_vertical"
    android:elevation="12dp">

    <TextView
        android:id="@+id/btnDrag"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⠿"
        android:textColor="#7CFC9A"
        android:textSize="20sp"
        android:paddingLeft="8dp"
        android:paddingRight="10dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp" />

    <View
        android:layout_width="1dp"
        android:layout_height="22dp"
        android:background="#33FFFFFF"
        android:layout_marginEnd="6dp" />

    <Button
        android:id="@+id/btnAddDot"
        style="?android:attr/buttonBarButtonStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="➕"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textAllCaps="false"
        android:paddingLeft="8dp"
        android:paddingRight="8dp" />

    <Button
        android:id="@+id/btnCapture"
        style="?android:attr/buttonBarButtonStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✨ AI Run"
        android:textColor="#4ADE80"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textAllCaps="false"
        android:paddingLeft="8dp"
        android:paddingRight="8dp" />

    <View
        android:layout_width="1dp"
        android:layout_height="22dp"
        android:background="#33FFFFFF"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp" />

    <!-- Emergency Stop/Start: force-kills or restarts ALL AI Touch activity
         (overlay, capture, everything). Does NOT trigger or loop any analysis. -->
    <Button
        android:id="@+id/btnStartStop"
        style="?android:attr/buttonBarButtonStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⏻ STOP"
        android:textColor="#F87171"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textAllCaps="false"
        android:paddingLeft="8dp"
        android:paddingRight="8dp" />

    <View
        android:layout_width="1dp"
        android:layout_height="22dp"
        android:background="#33FFFFFF"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp" />

    <Button
        android:id="@+id/btnMinimize"
        style="?android:attr/buttonBarButtonStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="—"
        android:textColor="#94A3B8"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textAllCaps="false"
        android:paddingLeft="6dp"
        android:paddingRight="6dp" />

    <Button
        android:id="@+id/btnClose"
        style="?android:attr/buttonBarButtonStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✕"
        android:textColor="#F87171"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textAllCaps="false"
        android:paddingLeft="6dp"
        android:paddingRight="4dp" />

</LinearLayout>
