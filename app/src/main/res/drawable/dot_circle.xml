<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="#4022C55E" />
        </shape>
    </item>
    <item
        android:top="4dp" android:bottom="4dp"
        android:left="4dp" android:right="4dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="24dp"
                android:startColor="#4ADE80"
                android:endColor="#16A34A" />
            <stroke android:width="2dp" android:color="#FFFFFF" />
        </shape>
    </item>
</layer-list>